#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")"

unset CLAUDECODE CLAUDE_CODE_ENTRYPOINT CLAUDE_CODE_ENABLE_TELEMETRY OTEL_EXPORTER_OTLP_ENDPOINT

PYTHON_BIN="{{PYTHON_BIN}}"
LOG_FILE="${ORCHESTRATOR_LOG_FILE:-{{LOG_FILE}}}"

if [[ ! -x "$PYTHON_BIN" && -x ".venv/bin/python" ]]; then
    PYTHON_BIN="$(pwd)/.venv/bin/python"
fi

if [[ ! -x "$PYTHON_BIN" ]]; then
    PYTHON_BIN="$(command -v python3 || command -v python)"
fi

if [[ "${1:-}" == "--fg" ]]; then
    echo "Starting orchestrator (foreground)..."
    "$PYTHON_BIN" -m orchestrator.main 2>&1 | tee "$LOG_FILE"
else
    echo "Starting orchestrator (background)..."
    nohup "$PYTHON_BIN" -m orchestrator.main > "$LOG_FILE" 2>&1 &
    PID=$!
    sleep 2
    if kill -0 "$PID" 2>/dev/null; then
        echo "Orchestrator started (PID: $PID)"
        echo "Log: $LOG_FILE"
    else
        echo "ERROR: Failed to start. Check $LOG_FILE"
        tail -20 "$LOG_FILE"
        exit 1
    fi
fi
